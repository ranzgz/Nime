{
  "rewrites":[
    {
      "source": "/api/:path*",
      "destination": "https://api.nefusoft.cloud/:path*"
    },
    {
      "source": "/(.*\\.mp4)",
      "has":[
        {
          "type": "query",
          "key": "url",
          "value": "(?<url>.*)"
        }
      ],
      "destination": "https://cf.elainaa.workers.dev/:url"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}